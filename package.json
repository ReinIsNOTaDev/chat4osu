{
  "name": "chat4osu",
  "version": "0.0.0",
  "description": "An IRC chat for osu!",
  "homepage": "https://hwchr.com/",
  "author": {
    "name": "Uwe Wiemer <hallowatcher>",
    "email": "hallowatcher@gmail.com"
  },
  "keywords": [
    "osu",
    "irc",
    "irc4osu",
    "chat4osu"
  ],
  "main": "main.js",
  "private": true,
  "scripts": {
    "postinstall": "npm run postinstall:electron && npx electron-builder install-app-deps",
    "postinstall:web": "node postinstall-web",
    "postinstall:electron": "node postinstall",
    "ng": "ng",
    "start": "npm run postinstall:electron && npm-run-all -p ng:serve electron:serve",
    "build": "npm run postinstall:electron && npm run electron:serve-tsc && ng build",
    "build:dev": "npm run build -- -c dev",
    "build:prod": "npm run build -- -c production",
    "ng:serve": "ng serve",
    "ng:serve:web": "npm run postinstall:web && ng serve -o",
    "electron:serve-tsc": "tsc -p tsconfig-serve.json",
    "electron:serve": "wait-on http-get://localhost:4200/ && npm run electron:serve-tsc && electron . --serve",
    "electron:local": "npm run build:prod && electron .",
    "electron:linux": "npm run build:prod && npx electron-builder build --linux",
    "electron:windows": "npm run build:prod && npx electron-builder build --windows",
    "electron:mac": "npm run build:prod && npx electron-builder build --mac",
    "test": "npm run postinstall:web && jest",
    "e2e": "npm run postinstall:web && ng e2e",
    "lint": "ng lint angular-electron"
  },
  "dependencies": {
    "@angular/animations": "^8.2.3",
    "@angular/cdk": "^8.2.2",
    "@ngneat/spectator": "^4.0.0",
    "@ngxs/form-plugin": "^3.5.0",
    "@ngxs/logger-plugin": "^3.5.0",
    "@ngxs/router-plugin": "^3.5.0",
    "@ngxs/store": "^3.5.0",
    "angular2-virtual-scroll": "^0.4.12",
    "electron-log": "^3.0.7",
    "electron-store": "^4.0.0",
    "electron-updater": "^4.1.2",
    "event-to-promise": "^0.8.0",
    "immer": "1.2.0",
    "irc-upd": "^0.10.0",
    "moment": "^2.22.2",
    "primeicons": "^1.0.0-beta.10",
    "primeng": "^6.1.3",
    "tslib": "^1.9.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~0.803.1",
    "@angular/cli": "8.3.1",
    "@angular/common": "8.2.3",
    "@angular/compiler": "8.2.3",
    "@angular/compiler-cli": "8.2.3",
    "@angular/core": "8.2.3",
    "@angular/forms": "8.2.3",
    "@angular/language-service": "8.2.3",
    "@angular/platform-browser": "8.2.3",
    "@angular/platform-browser-dynamic": "8.2.3",
    "@angular/router": "8.2.3",
    "@ngx-translate/core": "10.0.1",
    "@ngx-translate/http-loader": "3.0.1",
    "@types/jest": "^24.0.18",
    "@types/node": "^10.14.16",
    "codelyzer": "5.1.0",
    "core-js": "2.5.6",
    "electron": "^6.0.5",
    "electron-builder": "^21.2.0",
    "electron-reload": "^1.5.0",
    "jest": "^24.9.0",
    "jest-preset-angular": "^7.1.1",
    "npm-run-all": "4.1.3",
    "npx": "10.2.0",
    "protractor": "5.3.2",
    "rxjs": "6.5.2",
    "ts-node": "6.0.3",
    "tslint": "5.19.0",
    "typescript": "3.5.3",
    "wait-on": "2.1.0",
    "webdriver-manager": "12.1.1",
    "zone.js": "^0.10.2"
  },
  "jest": {
    "preset": "jest-preset-angular",
    "setupFilesAfterEnv": [
      "<rootDir>/src/app/setup-jest.ts"
    ]
  }
}
