{
  "name": "chat4osu",
  "version": "0.0.0",
  "description": "An IRC chat for osu!",
  "homepage": "https://gitlab.com/hallowatcher/chat4osu",
  "author": {
    "name": "Uwe Wiemer <hallowatcher>",
    "email": "hallowatcher@gmail.com"
  },
  "keywords": [
    "osu",
    "irc",
    "irc4osu",
    "chat4osu"
  ],
  "main": "main.js",
  "scripts": {
    "postinstall": "npx electron-builder install-app-deps",
    "postinstall:web": "node postinstall-web",
    "postinstall:electron": "node postinstall",
    "ng": "ng",
    "start": "npm-run-all -p ng:serve electron:serve",
    "build": "npm run electron:serve-tsc && ng build",
    "build:dev": "npm run build -- -c dev",
    "build:prod": "npm run build -- -c production",
    "ng:serve": "ng serve",
    "ng:serve:web": "ng serve -o",
    "electron:serve-tsc": "tsc -p tsconfig-serve.json",
    "electron:serve": "wait-on tcp:4200 && npm run electron:serve-tsc && npx electron . --serve",
    "electron:local": "npm run build:prod && electron .",
    "electron:linux": "npm run build:prod && npx electron-builder build --linux",
    "electron:windows": "npm run build:prod && npx electron-builder build --windows",
    "electron:mac": "npm run build:prod && npx electron-builder build --mac",
    "test": "npm run postinstall:web && jest",
    "e2e": "npm run postinstall:web && ng e2e",
    "lint": "ng lint angular-electron"
  },
  "dependencies": {
    "@angular/animations": "^21.1.1",
    "@angular/cdk": "^21.1.1",
    "@angular/forms": "^21.1.1",
    "@angular/material": "^21.1.1",
    "@ngxs/form-plugin": "^21.0.0",
    "@ngxs/logger-plugin": "^21.0.0",
    "@ngxs/router-plugin": "^21.0.0",
    "@ngxs/store": "^21.0.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.7.3",
    "event-to-promise": "^0.8.0",
    "hotkeys-js": "^4.0.0",
    "howler": "^2.2.4",
    "immer": "11.1.3",
    "irc-upd": "^0.11.0",
    "moment": "^2.30.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.0.4",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^21.0.3",
    "@angular-devkit/build-angular": "~21.1.1",
    "@angular/cli": "21.1.1",
    "@angular/common": "^21.1.1",
    "@angular/compiler": "21.1.1",
    "@angular/compiler-cli": "21.1.1",
    "@angular/core": "21.1.1",
    "@angular/language-service": "21.1.1",
    "@angular/platform-browser": "^21.1.1",
    "@angular/platform-browser-dynamic": "21.1.1",
    "@angular/router": "21.1.1",
    "@ngneat/spectator": "^22.1.0",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "@types/howler": "^2.2.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.10",
    "core-js": "3.48.0",
    "cross-env": "^7.0.3",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "electron-reload": "^1.5.0",
    "jest": "^30.2.0",
    "jest-preset-angular": "^16.0.0",
    "ng-mocks": "^14.15.0",
    "npm-run-all": "^4.1.5",
    "npx": "10.2.2",
    "rxjs": "7.8.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "wait-on": "^9.0.3",
    "zone.js": "~0.16.0"
  },
  "jest": {
    "preset": "jest-preset-angular",
    "setupFilesAfterEnv": [
      "<rootDir>/src/app/setup-jest.ts"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
